                <mxCell id="9XMJNWGPIjfMtGDZM7Im-94" value="&lt;b&gt;un pedido puede tener uno o&amp;nbsp;&lt;/b&gt;&lt;div&gt;&lt;b&gt;varios pagos asociados&lt;/b&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=1;autosize=1;resizable=0;" parent="1" vertex="1">
