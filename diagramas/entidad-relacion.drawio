                <mxCell id="9XMJNWGPIjfMtGDZM7Im-96" value="&lt;b&gt;relacion uno a muchos ,&lt;/b&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp;order_audit registra&lt;/b&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp;modificaciones sobre ciertos&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;campos del pedido&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=1;autosize=1;resizable=0;" parent="1" vertex="1">
