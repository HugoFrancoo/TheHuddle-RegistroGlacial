                </mxCell>
                <mxCell id="9XMJNWGPIjfMtGDZM7Im-95" value="&lt;b&gt;el estado de un pedido no es estatico,&lt;/b&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp;evoluciona con el tiempo&lt;/b&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=1;autosize=1;resizable=0;" parent="1" vertex="1">
