                <mxCell id="9XMJNWGPIjfMtGDZM7Im-83" value="&lt;b&gt;cada pedido puede contener varios productos,&lt;/b&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp;y cada producto puede estar en multiples pedidos&lt;/b&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=1;autosize=1;resizable=0;" parent="1" vertex="1">
